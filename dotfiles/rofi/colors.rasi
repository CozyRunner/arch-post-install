* {
    background:     rgba(30, 30, 46, 0.8);
    background-alt: rgba(49, 50, 68, 0.8);
    selected:       #89b4fa;
    foreground:     #cdd6f4;
    foreground-dim: #6c7086;
    accent:         #89b4fa;
    border:         rgba(137, 180, 250, 0.4);

    /* Compatibility aliases */
    bg:      @background;
    bg-alt:  @background-alt;
    fg:      @foreground;
    fg-dim:  @foreground-dim;
    sel:     @selected;
    bg-sel:  @background-alt;
    accent:  @selected;
}
